generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "sqlite"
}

model Prompt {
  id          String          @id @default(cuid())
  title       String
  description String?
  content     String
  category    String?
  model       String?
  favorite    Boolean         @default(false)
  deleted     Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([deleted])
  @@index([favorite, deleted])
  @@index([category, deleted])
  @@index([updatedAt])
  @@index([createdAt])
}



